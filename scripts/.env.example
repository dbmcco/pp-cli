# ABOUTME: Example environment file for morning briefing
# ABOUTME: Copy to .env and add your API keys

# Anthropic API key for Claude summarization (optional - falls back to Perplexity)
ANTHROPIC_API_KEY=your_key_here

# Perplexity pp CLI path (optional - auto-detected from PATH)
# PP_CLI_PATH=/opt/homebrew/bin/pp
# Note: ensure this is Perplexity CLI, not the NSS ASN.1 `pp` utility.

# Timeout in seconds for each pp CLI request (optional, default: 180)
# PP_CLI_TIMEOUT_SECONDS=180
